      {
        "_comment": "3. PLANTED: API key exposed in a query string. URL-bound secrets show up in browser history, server logs, and Referer headers.",
        "startedDateTime": "2026-05-04T14:00:00.420Z",
        "time": 95,
        "request": {
          "method": "GET",
          "url": "https://api.weather.example.org/forecast?lat=40.76&lon=-111.89&api_key=wx_live_sk_4f2a8c1e9b0d7e3a5c6f8d9b0a1c2e3f",
          "httpVersion": "HTTP/2",
          "cookies": [],
          "headers": [
            { "name": "Host", "value": "api.weather.example.org" },
            { "name": "Accept", "value": "application/json" }
          ],
          "queryString": [
            { "name": "lat",     "value": "40.76" },
            { "name": "lon",     "value": "-111.89" },
            { "name": "api_key", "value": "wx_live_sk_4f2a8c1e9b0d7e3a5c6f8d9b0a1c2e3f" }
          ],
          "headersSize": -1,
          "bodySize": 0
        },
        "response": {
          "status": 200,
