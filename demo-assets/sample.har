          "bodySize": 124
        },
        "cache": {},
        "timings": { "send": 2, "wait": 88, "receive": 5 }
      },

      {
        "_comment": "4. PLANTED: session cookie sent cross-origin to a CDN that does not need it. Common misconfiguration: cookie scoped to .example.com instead of app.example.com.",
        "startedDateTime": "2026-05-04T14:00:00.560Z",
        "time": 75,
        "request": {
          "method": "GET",
          "url": "https://cdn.example.com/static/avatar/42.png",
          "httpVersion": "HTTP/2",
          "cookies": [
            { "name": "session", "value": "s%3Aabc123.signed-session-id-xyz" }
          ],
          "headers": [
            { "name": "Cookie", "value": "session=s%3Aabc123.signed-session-id-xyz" },
            { "name": "Host", "value": "cdn.example.com" },
            { "name": "Accept", "value": "image/avif,image/webp,*/*" }
          ],
          "queryString": [],
          "headersSize": -1,
          "bodySize": 0
        },
        "response": {
          "status": 200,
          "statusText": "OK",
          "httpVersion": "HTTP/2",
          "cookies": [],
          "headers": [{ "name": "Content-Type", "value": "image/png" }],
          "content": { "size": 4096, "mimeType": "image/png" },
          "redirectURL": "",
          "headersSize": -1,
          "bodySize": 4096
        },
        "cache": {},
        "timings": { "send": 1, "wait": 70, "receive": 4 }
      },

      {
