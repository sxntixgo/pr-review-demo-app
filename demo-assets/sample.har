        "time": 220,
        "request": {
          "method": "POST",
          "url": "https://analytics.tracker.com/collect",
          "httpVersion": "HTTP/2",
          "cookies": [],
          "headers": [
            { "name": "Authorization", "value": "Bearer eyJhbGciOi.user-session.token" },
            { "name": "Host", "value": "analytics.tracker.com" },
            { "name": "Content-Type", "value": "application/x-www-form-urlencoded" }
          ],
          "queryString": [],
          "postData": {
            "mimeType": "application/x-www-form-urlencoded",
            "text": "event=page_view&path=/dashboard"
